# Copy to .env and fill in — YOU bring your own LLM key.
# The agent uses this model to generate attack payloads and reason about replies.

# Provider: anthropic | openai | groq | openrouter | ollama | custom
PIXA_LLM_PROVIDER=openrouter

# Model id (provider-specific). A few good picks:
#   anthropic   -> claude-haiku-4-5-20251001
#   openai      -> gpt-4o-mini
#   groq        -> llama-3.3-70b-versatile
#   openrouter  -> anthropic/claude-3.5-haiku
#   ollama      -> llama3.1:8b   (local, no key)
PIXA_LLM_MODEL=anthropic/claude-3.5-haiku

# API key for the provider above. NOT needed for ollama.
PIXA_LLM_API_KEY=

# Only for provider=ollama
PIXA_OLLAMA_URL=http://localhost:11434
